# Copy to .env.local for local dev. In GitHub Actions, set these as repo secrets.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Canonical site root (Open Graph image + redirects). Example: https://ryazlee.github.io/slumber-web
VITE_SITE_URL=https://your-user.github.io/slumber-web
# Optional override for share links with rich iMessage previews (defaults to VITE_SUPABASE_URL/functions/v1/link-preview)
# VITE_LINK_PREVIEW_BASE_URL=https://your-project.supabase.co/functions/v1/link-preview
