# Copy to .env.local for local dev. In GitHub Actions, set these as repo secrets.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ─── Public site URL (keep in sync with app EXPO_PUBLIC_WEB_BASE_URL) ────────
# Full URL including any GitHub Pages repo path. Custom domain: https://slumber.app
VITE_SITE_URL=https://your-user.github.io/slumber-web

# Vite asset + universal-link path prefix. `/` for custom domain root; `/slumber-web` on GitHub Pages.
VITE_BASE_PATH=/slumber-web
