# Copy to .env.local for local dev. In GitHub Actions, set these as repo secrets.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ─── Public site URL (keep in sync with app EXPO_PUBLIC_WEB_BASE_URL) ────────
# Custom domain (production): https://useslumber.com
VITE_SITE_URL=https://useslumber.com

# Vite asset + universal-link path prefix. `/` for custom domain root; `/slumber-web` on GitHub Pages.
VITE_BASE_PATH=/

# Supabase Auth → URL Configuration → Redirect URLs must include:
#   ${VITE_SITE_URL}/login-callback
#   https://ryazlee.github.io/slumber-web/login-callback   (legacy, while still live)
#
# Google OAuth: enable Authentication → Providers → Google in Supabase dashboard.
